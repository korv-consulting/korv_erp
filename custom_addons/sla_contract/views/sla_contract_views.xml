<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action -->
    <record id="action_sla_contract" model="ir.actions.act_window">
        <field name="name">SLA Contracts</field>
        <field name="res_model">sla.contract</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p>
                Créez ici les contrats de SLA liés à vos commandes de vente.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_sla_contract"
        name="SLA"
        parent="sale.sale_order_menu"
        action="action_sla_contract"
        sequence="30"
    />

    <!-- Tree view -->
    <record id="view_sla_contract_tree" model="ir.ui.view">
        <field name="name">sla.contract.tree</field>
        <field name="model">sla.contract</field>
        <field name="arch" type="xml">
            <tree string="SLA Contracts">
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="mission_name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_sla_contract_form" model="ir.ui.view">
        <field name="name">sla.contract.form</field>
        <field name="model">sla.contract</field>
        <field name="arch" type="xml">
            <form string="SLA Contract">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sale_order_id"/>
                            <field name="partner_id"/>
                            <field name="mission_name"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="state"/>
                            <field name="support_hours"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Engagements SLA">
                            <group>
                                <field name="response_time"/>
                                <field name="resolution_time"/>
                            </group>
                        </page>
                        <page string="Détails">
                            <group>
                                <field name="scope"/>
                                <field name="exclusions"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>

