<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Bouton \"Créer SLA\" sur le bon de commande -->
    <record id="view_order_form_inherit_sla" model="ir.ui.view">
        <field name="name">sale.order.form.sla</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_open_sla_contract"
                    type="object"
                    string="Créer SLA"
                    class="btn-secondary"
                />
            </xpath>
        </field>
    </record>

</odoo>

