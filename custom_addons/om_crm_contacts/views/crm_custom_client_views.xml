<?xml version="1.0" encoding="utf-8"?>
<odoo>
  
    <record id="res_partner_custom_form" model="ir.ui.view">
        <field name="name">res.partner.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">

            <xpath expr="//div[@class='o_row']" position="after">
                <group name="company_info">
                    <field name="activity_area_id" class="oe_inline"/>
                    <field name="company_size_id" class="oe_inline"/>
                </group>
            </xpath>

            <xpath expr="//field[@name='vat']" position="after">
                <group name="company_identification">
                    <field name="rccm"  string="RCCM/SIREN" placeholder="Ex: RCCM123456" invisible="not is_company"/>
                    <field name="nui"  string="NUI"  placeholder="Ex: NUI123456" invisible="not is_company"/>
                </group>
            </xpath>

            <xpath expr="//page[@name='contact_addresses']" position="attributes">
                    <attribute name="string">Contacts</attribute>
            </xpath>

            <xpath expr="//page[@name='sales_purchases']" position="attributes">
                    <attribute name="string">Suivi</attribute>
            </xpath>

             <xpath expr="//page[@name='sales_purchases']//group[@name='sale']" position="attributes">
                    <attribute name="string">Direction commerciale</attribute>
            </xpath>

            <xpath expr="//group[@name='misc']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//group[@name='purchase']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//div[contains(@class,'o_address_format')]//field[@name='state_id']" 
                    position="attributes">
                <attribute name="placeholder">Région / État</attribute>
            </xpath>

            <xpath expr="//field[@name='child_ids']/form/sheet//div[@class='o_address_format']//field[@name='state_id']"
                    position="attributes">
                <attribute name="placeholder">Région / État</attribute>
            </xpath>

           <xpath expr="//field[@name='team_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="(//field[@name='team_id'])[2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            
            <xpath expr="//page[@name='sales_purchases']//group[@name='container_row_2']//group[@name='sale']//field[@name='user_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//page[@name='contact_addresses']//p[3]/span" position="replace">
                <span>
                    Adresse préférée pour toutes les prestations.
                    Sélectionnée par défaut lorsque vous créez une prestation pour cette société.
                </span>
            </xpath>

            <xpath expr="//page[@name='sales_purchases']//group[@name='container_row_2']//group[@name='sale']//field[@name='user_id']" position="after">
                <field name="department_id"/>
                <field name="employee_id"/>
            </xpath>

        </field>
    </record>

    <!-- Liste -->
    <record id="res_partner_custom_tree" model="ir.ui.view">
        <field name="name">res.partner.tree</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='complete_name']" position="after">
                <field name="rccm"/>
                <field name="nui"/>
            </xpath>

            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>


        </field>
    </record>
</odoo>