<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_lost_form_custom" model="ir.ui.view">
        <field name="name">crm.lead.lost.form.custom</field>
        <field name="model">crm.lead.lost</field>
        <field name="inherit_id" ref="crm.crm_lead_lost_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/group" position="inside">
                <field name="opportunity_lost"/>
                <field name="loss_date"/>
                <field name="winning_competitor"/>
                <field name="price_gap"/>
                <field name="lessons_learned"/>
                <field name="future_recontact_possible"/>
                <field name="potential_recontact_date"/>
            </xpath>
        </field>
    </record>
</odoo>