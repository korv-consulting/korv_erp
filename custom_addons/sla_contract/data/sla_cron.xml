<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1"> <!-- noupdate="1" empêche d'écraser tes réglages personnalisés si on réinstalle le module -->
        <record id="ir_cron_check_sla_expiration" model="ir.cron">
            <field name="name">SLA: Check Expiration Daily</field>
            <field name="model_id" ref="model_sla_contract"/>
            <field name="state">code</field>
            <field name="code">model.cron_check_sla_expiration()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field> <!-- -1 signifie s'exécute indéfiniment -->
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
