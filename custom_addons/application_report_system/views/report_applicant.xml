<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="applicant_report_template">

<t t-call="web.basic_layout">
<main>

<style> 
    body { 
        font-family: Arial, sans-serif; font-size: 12px; color: #222;
    } 
    body, main {
        margin: 0;
        padding: 0;
    }
    .page {
        page-break-after: always;
        margin: 0;
        padding: 0;
    }
    h2 { margin-bottom: 20px; letter-spacing: 1px; } 
    .section-title { background-color: #1F739A; color: white; padding: 8px; font-weight: bold; text-transform: uppercase; margin-top: 20px; margin-bottom: 10px; font-size: 13px; } 
    .info-table td { border: 1px solid #ccc; padding: 6px; } 
    .criteria-table th { background-color: #E6EEF5; border: 1px solid #999; padding: 6px; font-weight: bold; } 
    .criteria-table td { border: 1px solid #ccc; padding: 6px; } 
    .text-block { border: 1px solid #ccc; padding: 10px; min-height: 60px; text-align: justify; } 
    .signature-box { border-top: 2px solid #1F739A; margin-top: 40px; padding-top: 15px; } 
    .footer-text { text-align: center; margin-top: 30px; font-size: 10px; color: #666; } 
</style>

<t t-foreach="docs" t-as="doc">

<div class="page">

<!-- HEADER -->
